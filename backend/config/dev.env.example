# Ambiente di sviluppo — copia in backend/.env
APP_ENV=dev
DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=sqlite:///./data/ticket_ai_manager.sqlite3
CORS_ORIGINS=["http://localhost:5173","app://."]
WORKER_PARALLEL=false
WORKER_CONCURRENCY=2

# OAuth2 Microsoft (Outlook) — necessari solo per account Outlook.
# Registra un'app su Azure (Entra) come client pubblico con questo redirect URI.
MS_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/email/oauth/callback
# Client_id dell'app Azure (lasciare vuoto se lo imposti per singolo account).
MS_OAUTH_CLIENT_ID=
