# File .env di default. Per ambienti specifici vedi config/{dev,staging,prod}.env.example
# Copia questo file in backend/.env e adatta i valori.
APP_ENV=dev
DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=sqlite:///./data/ticket_ai_manager.sqlite3
CORS_ORIGINS=["http://localhost:5173","app://."]
WORKER_PARALLEL=false
WORKER_CONCURRENCY=2

# OAuth2 Microsoft (Outlook) — solo per account Outlook (vedi README integrazione email).
MS_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/email/oauth/callback
MS_OAUTH_CLIENT_ID=
